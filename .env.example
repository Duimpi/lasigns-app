# ============================================================
# LA SIGNS & GRAPHICS CC — Environment Variables
# Copy to .env.local and fill in your Supabase credentials
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Optional: Service role key for server-side operations (keep secret!)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Email (optional — for future SMTP integration)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=baganiholdings@gmail.com
# SMTP_PASS=YOUR_APP_PASSWORD
